generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id             String           @id @default(uuid())
  name           String
  slug           String           @unique
  email          String
  phone          String?
  address        String?
  country        String           @default("DO")
  status         TenantStatus     @default(ACTIVE)
  plan           PlanType         @default(BASIC)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  rnc            String?
  logo           String?
  subdomain      String           @unique @default("")
  customDomain   String?          @unique
  databaseName   String           @default("")
  databaseUrl    String           @default("")
  settings       Json?
  limits         Json?
  billingEmail   String           @default("")
  subscriptionId String?
  trialEndsAt    DateTime?        @db.Timestamp(6)
  lastActiveAt   DateTime?        @db.Timestamp(6)
  users          MasterUser[]
  subscriptions  Subscription[]
  invoices       TenantInvoice[]
  activities     TenantActivity[]

  @@index([slug])
  @@index([status])
}

model MasterUser {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  name      String
  role      MasterRole @default(SUPPORT)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenantId  String?
  tenant    Tenant?    @relation(fields: [tenantId], references: [id])

  @@index([email])
}

model Subscription {
  id           String             @id @default(uuid())
  tenantId     String
  plan         PlanType
  status       SubscriptionStatus @default(ACTIVE)
  startDate    DateTime
  endDate      DateTime?
  billingCycle BillingCycle       @default(MONTHLY)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  tenant       Tenant             @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  password             String
  name                 String
  phone                String?
  role                 Role                  @default(OPERATOR)
  isActive             Boolean               @default(true)
  lastLogin            DateTime?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  branchId             String?
  managedBranches      Branch[]              @relation("BranchManager")
  cashMovements        CashMovement[]
  closedCashRegisters  CashRegister[]        @relation("ClosedCashRegister")
  openedCashRegisters  CashRegister[]        @relation("OpenedCashRegister")
  creditNotes          CreditNote[]
  inventoryAdjustments InventoryAdjustment[]
  inventoryMovements   InventoryMovement[]
  invoices             Invoice[]
  payments             Payment[]
  quotes               Quote[]
  tasks                Task[]
  appointments         Appointment[]
  branch               Branch?               @relation("UserBranch", fields: [branchId], references: [id])
  purchases            Purchase[]
  supplierPayments     SupplierPayment[]
  requestedLoans       Loan[]                @relation("LoanRequestedBy")
  approvedLoans        Loan[]                @relation("LoanApprovedBy")
  rejectedLoans        Loan[]                @relation("LoanRejectedBy")
  disbursedLoans       Loan[]                @relation("LoanDisbursedBy")
  cancelledLoans       Loan[]                @relation("LoanCancelledBy")
  receivableFinancingPlans ReceivableFinancingPlan[]
  loanPayments         LoanPayment[]
  reversedLoanPayments LoanPayment[]         @relation("LoanPaymentReversedBy")
  loanLedgerEntries    LoanLedger[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@index([branchId])
}

model Client {
  id             String        @id @default(uuid())
  name           String
  identification String
  email          String?
  phone          String?
  address        String?
  creditLimit    Decimal?      @default(0) @db.Decimal(10, 2)
  creditDays     Int           @default(30)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  invoices       Invoice[]
  payments       Payment[]
  quotes         Quote[]
  tasks          Task[]
  loans          Loan[]
  loanPayments   LoanPayment[]
  receivableFinancingPlans ReceivableFinancingPlan[]

  @@index([name])
  @@index([identification])
  @@index([isActive])
}

model Branch {
  id                 String                @id @default(uuid())
  name               String                @unique
  address            String?
  phone              String?
  isActive           Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  code               String?               @unique
  email              String?
  managerId          String?
  manager            User?                 @relation("BranchManager", fields: [managerId], references: [id])
  cashRegisters      CashRegister[]
  adjustments        InventoryAdjustment[]
  inventoryMovements InventoryMovement[]
  invoices           Invoice[]
  ncfSequences       NcfSequence[]
  stocks             Stock[]
  users              User[]                @relation("UserBranch")
  appointments       Appointment[]
  purchases          Purchase[]
  supplierInvoices   SupplierInvoice[]
  supplierPayments   SupplierPayment[]
  loans              Loan[]
  loanPayments       LoanPayment[]
  receivableFinancingPlans ReceivableFinancingPlan[]

  @@index([code])
  @@index([managerId])
  @@index([name])
  @@index([isActive])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([name])
  @@index([isActive])
}

model Product {
  id              String                    @id @default(uuid())
  code            String                    @unique
  barcode         String?                   @unique
  name            String
  description     String?
  categoryId      String
  brand           String?
  unit            String                    @default("UNIT")
  salePrice       Decimal                   @db.Decimal(10, 2)
  cost            Decimal?                  @db.Decimal(10, 2)
  hasTax          Boolean                   @default(true)
  taxPercent      Decimal                   @default(18) @db.Decimal(5, 2)
  controlsStock   Boolean                   @default(true)
  minStock        Decimal                   @default(0) @db.Decimal(10, 2)
  isActive        Boolean                   @default(true)
  imageUrl        String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  creditNoteItems CreditNoteItem[]
  adjustmentItems InventoryAdjustmentItem[]
  movements       InventoryMovement[]
  invoiceItems    InvoiceItem[]
  category        Category                  @relation(fields: [categoryId], references: [id])
  quoteItems      QuoteItem[]
  stocks          Stock[]
  purchaseItems   PurchaseItem[]

  @@index([code])
  @@index([barcode])
  @@index([categoryId])
  @@index([isActive])
}

model Stock {
  id        String   @id @default(uuid())
  productId String
  branchId  String
  quantity  Decimal  @default(0) @db.Decimal(10, 2)
  minStock  Decimal  @default(0) @db.Decimal(10, 2)
  updatedAt DateTime @updatedAt
  branch    Branch   @relation(fields: [branchId], references: [id])
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId], name: "productId_branchId")
  @@index([productId])
  @@index([branchId])
}

model Invoice {
  id                 String        @id @default(uuid())
  number             String        @unique
  ncf                String?       @unique
  clientId           String?
  type               InvoiceType   @default(FISCAL)
  status             InvoiceStatus @default(ISSUED)
  paymentMethod      PaymentMethod
  subtotal           Decimal       @db.Decimal(10, 2)
  tax                Decimal       @default(0) @db.Decimal(10, 2)
  discount           Decimal       @default(0) @db.Decimal(10, 2)
  total              Decimal       @db.Decimal(10, 2)
  balance            Decimal       @default(0) @db.Decimal(10, 2)
  issueDate          DateTime      @default(now())
  dueDate            DateTime?
  userId             String
  branchId           String?
  observations       String?
  cancelledAt        DateTime?
  cancellationReason String?
  cancelledBy        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  creditNotes        CreditNote[]
  branch             Branch?       @relation(fields: [branchId], references: [id])
  client             Client?       @relation(fields: [clientId], references: [id])
  user               User          @relation(fields: [userId], references: [id])
  items              InvoiceItem[]
  payments           Payment[]
  financedLoans      Loan[]        @relation("FinancedSaleLoan")
  receivableFinancingPlan ReceivableFinancingPlan?

  @@index([number])
  @@index([ncf])
  @@index([clientId])
  @@index([status])
  @@index([issueDate])
  @@index([dueDate])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  price       Decimal  @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
}

model Quote {
  id                   String      @id @default(uuid())
  number               String      @unique
  clientId             String?
  status               QuoteStatus @default(OPEN)
  subtotal             Decimal     @db.Decimal(10, 2)
  tax                  Decimal     @default(0) @db.Decimal(10, 2)
  discount             Decimal     @default(0) @db.Decimal(10, 2)
  total                Decimal     @db.Decimal(10, 2)
  validUntil           DateTime?
  userId               String
  convertedToInvoiceId String?     @unique
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  client               Client?     @relation(fields: [clientId], references: [id])
  user                 User        @relation(fields: [userId], references: [id])
  items                QuoteItem[]

  @@index([number])
  @@index([clientId])
  @@index([status])
}

model QuoteItem {
  id          String   @id @default(uuid())
  quoteId     String
  productId   String?
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  price       Decimal  @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  product     Product? @relation(fields: [productId], references: [id])
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model CreditNote {
  id        String           @id @default(uuid())
  number    String           @unique
  ncf       String?          @unique
  invoiceId String
  reason    String
  subtotal  Decimal          @db.Decimal(10, 2)
  tax       Decimal          @default(0) @db.Decimal(10, 2)
  total     Decimal          @db.Decimal(10, 2)
  issueDate DateTime         @default(now())
  userId    String
  createdAt DateTime         @default(now())
  invoice   Invoice          @relation(fields: [invoiceId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
  items     CreditNoteItem[]

  @@index([number])
  @@index([invoiceId])
  @@index([issueDate])
}

model CreditNoteItem {
  id           String     @id @default(uuid())
  creditNoteId String
  productId    String?
  description  String
  quantity     Decimal    @db.Decimal(10, 2)
  price        Decimal    @db.Decimal(10, 2)
  subtotal     Decimal    @db.Decimal(10, 2)
  createdAt    DateTime   @default(now())
  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  product      Product?   @relation(fields: [productId], references: [id])

  @@index([creditNoteId])
}

model Payment {
  id           String        @id @default(uuid())
  clientId     String
  invoiceId    String?
  amount       Decimal       @db.Decimal(10, 2)
  method       PaymentMethod
  reference    String?
  paymentDate  DateTime      @default(now())
  observations String?
  userId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  client       Client        @relation(fields: [clientId], references: [id])
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id])
  user         User          @relation(fields: [userId], references: [id])

  @@index([clientId])
  @@index([invoiceId])
  @@index([paymentDate])
}

model ReceivableFinancingPlan {
  id                String                      @id @default(uuid())
  invoiceId         String                      @unique
  clientId          String
  branchId          String?
  createdById       String
  principalAmount   Decimal                     @db.Decimal(12, 2)
  annualInterestRate Decimal                    @db.Decimal(7, 4)
  termMonths        Int
  paymentFrequency  LoanPaymentFrequency        @default(MONTHLY)
  startDate         DateTime
  firstDueDate      DateTime
  endDate           DateTime
  installmentAmount Decimal                     @db.Decimal(12, 2)
  totalInterest     Decimal                     @db.Decimal(12, 2)
  totalFinanced     Decimal                     @db.Decimal(12, 2)
  paidAmount        Decimal                     @default(0) @db.Decimal(12, 2)
  remainingAmount   Decimal                     @db.Decimal(12, 2)
  status            ReceivableFinancingStatus   @default(ACTIVE)
  notes             String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  invoice           Invoice                     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  client            Client                      @relation(fields: [clientId], references: [id])
  branch            Branch?                     @relation(fields: [branchId], references: [id])
  createdBy         User                        @relation(fields: [createdById], references: [id])
  installments      ReceivableInstallment[]

  @@index([clientId])
  @@index([branchId])
  @@index([status])
}

model ReceivableInstallment {
  id                 String                         @id @default(uuid())
  financingPlanId    String
  installmentNo      Int
  dueDate            DateTime
  openingBalance     Decimal                        @db.Decimal(12, 2)
  scheduledPrincipal Decimal                        @db.Decimal(12, 2)
  scheduledInterest  Decimal                        @db.Decimal(12, 2)
  scheduledTotal     Decimal                        @db.Decimal(12, 2)
  paidAmount         Decimal                        @default(0) @db.Decimal(12, 2)
  paidPrincipal      Decimal                        @default(0) @db.Decimal(12, 2)
  paidInterest       Decimal                        @default(0) @db.Decimal(12, 2)
  status             ReceivableInstallmentStatus    @default(PENDING)
  paidAt             DateTime?
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt

  financingPlan      ReceivableFinancingPlan        @relation(fields: [financingPlanId], references: [id], onDelete: Cascade)

  @@unique([financingPlanId, installmentNo])
  @@index([financingPlanId])
  @@index([dueDate])
  @@index([status])
}

model CashRegister {
  id            String         @id @default(uuid())
  branchId      String
  status        CashStatus     @default(CLOSED)
  initialAmount Decimal        @db.Decimal(10, 2)
  finalAmount   Decimal?       @db.Decimal(10, 2)
  difference    Decimal?       @default(0) @db.Decimal(10, 2)
  openedAt      DateTime
  closedAt      DateTime?
  openedBy      String
  closedBy      String?
  observations  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  movements     CashMovement[]
  loanPayments  LoanPayment[]
  branch        Branch         @relation(fields: [branchId], references: [id])
  closedByUser  User?          @relation("ClosedCashRegister", fields: [closedBy], references: [id])
  openedByUser  User           @relation("OpenedCashRegister", fields: [openedBy], references: [id])

  @@index([branchId])
  @@index([status])
  @@index([openedAt])
}

model CashMovement {
  id             String        @id @default(uuid())
  cashRegisterId String
  type           MovementType
  concept        String
  amount         Decimal       @db.Decimal(10, 2)
  method         PaymentMethod
  invoiceId      String?
  paymentId      String?
  userId         String
  movementDate   DateTime      @default(now())
  observations   String?
  createdAt      DateTime      @default(now())
  cashRegister   CashRegister  @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id])

  @@index([cashRegisterId])
  @@index([type])
  @@index([movementDate])
}

model InventoryMovement {
  id           String                @id @default(uuid())
  productId    String
  branchId     String
  type         InventoryMovementType
  quantity     Decimal               @db.Decimal(10, 2)
  balance      Decimal               @db.Decimal(10, 2)
  documentType String?
  documentId   String?
  userId       String
  movementDate DateTime              @default(now())
  observations String?
  createdAt    DateTime              @default(now())
  branch       Branch                @relation(fields: [branchId], references: [id])
  product      Product               @relation(fields: [productId], references: [id])
  user         User                  @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([branchId])
  @@index([type])
  @@index([movementDate])
}

model InventoryAdjustment {
  id             String                    @id @default(uuid())
  branchId       String
  type           AdjustmentType
  reason         String
  userId         String
  adjustmentDate DateTime                  @default(now())
  observations   String?
  createdAt      DateTime                  @default(now())
  branch         Branch                    @relation(fields: [branchId], references: [id])
  user           User                      @relation(fields: [userId], references: [id])
  items          InventoryAdjustmentItem[]

  @@index([branchId])
  @@index([adjustmentDate])
}

model InventoryAdjustmentItem {
  id                 String              @id @default(uuid())
  adjustmentId       String
  productId          String
  previousQuantity   Decimal             @db.Decimal(10, 2)
  adjustmentQuantity Decimal             @db.Decimal(10, 2)
  newQuantity        Decimal             @db.Decimal(10, 2)
  createdAt          DateTime            @default(now())
  adjustment         InventoryAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  product            Product             @relation(fields: [productId], references: [id])

  @@index([adjustmentId])
  @@index([productId])
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  clientId    String?
  userId      String
  status      String    @default("PENDING")
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  priority    String    @default("MEDIUM")
  client      Client?   @relation(fields: [clientId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@index([clientId])
  @@index([userId])
  @@index([status])
  @@index([priority])
}

model NcfSequence {
  id            String    @id @default(uuid())
  prefix        String
  description   String?
  startRange    Int
  endRange      Int
  currentNumber Int       @default(0)
  isActive      Boolean   @default(true)
  validFrom     DateTime  @default(now())
  validUntil    DateTime?
  branchId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  branch        Branch?   @relation(fields: [branchId], references: [id])

  @@index([prefix])
  @@index([isActive])
  @@index([branchId])
  @@index([validUntil])
}

model WhatsAppTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  type      String
  subject   String?
  message   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
}

model Appointment {
  id              String    @id @default(uuid())
  clientName      String
  clientEmail     String?
  clientPhone     String
  appointmentDate DateTime
  duration        Int       @default(60)
  notes           String?
  status          String    @default("PENDING")
  source          String    @default("MANUAL")
  isViewed        Boolean   @default(false)
  viewedAt        DateTime?
  isNotified      Boolean   @default(false)
  notifiedAt      DateTime?
  branchId        String?
  userId          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([branchId])
  @@index([appointmentDate])
  @@index([isViewed])
}

model Loan {
  id                 String                 @id @default(uuid())
  number             String                 @unique
  clientId           String
  branchId           String?
  requestedById      String
  approvedById       String?
  rejectedById       String?
  disbursedById      String?
  cancelledById      String?
  amount             Decimal                @db.Decimal(12, 2)
  interestRate       Decimal                @db.Decimal(5, 2)
  termMonths         Int
  paymentFrequency   LoanPaymentFrequency   @default(MONTHLY)
  productType        LoanProductType        @default(CASH_LOAN)
  amortizationMethod LoanAmortizationMethod @default(FIXED_PAYMENT)
  graceDays          Int                    @default(0)
  lateInterestRate   Decimal                @default(0) @db.Decimal(7, 4)
  startDate          DateTime
  applicationDate    DateTime               @default(now())
  firstPaymentDate   DateTime
  endDate            DateTime
  disbursementDate   DateTime?
  status             LoanStatus             @default(DRAFT)
  purpose            String
  collateral         String?
  guarantee          String?
  notes              String?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  rejectionReason    String?
  disbursedAt        DateTime?
  cancelledAt        DateTime?
  cancelReason       String?
  installmentAmount  Decimal?               @db.Decimal(12, 2)
  projectedInterest  Decimal?               @db.Decimal(12, 2)
  projectedFees      Decimal?               @db.Decimal(12, 2)
  paidPrincipal      Decimal                @default(0) @db.Decimal(12, 2)
  paidInterest       Decimal                @default(0) @db.Decimal(12, 2)
  paidLateFees       Decimal                @default(0) @db.Decimal(12, 2)
  paidFees           Decimal                @default(0) @db.Decimal(12, 2)
  overdueBalance     Decimal                @default(0) @db.Decimal(12, 2)
  paidAmount         Decimal                @default(0) @db.Decimal(12, 2)
  remainingAmount    Decimal                @default(0) @db.Decimal(12, 2)
  nextPaymentDate    DateTime?
  overdueDays        Int                    @default(0)
  saleInvoiceId      String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  branch             Branch?                @relation(fields: [branchId], references: [id])
  client             Client                 @relation(fields: [clientId], references: [id])
  requestedBy        User                   @relation("LoanRequestedBy", fields: [requestedById], references: [id])
  approvedBy         User?                  @relation("LoanApprovedBy", fields: [approvedById], references: [id])
  rejectedBy         User?                  @relation("LoanRejectedBy", fields: [rejectedById], references: [id])
  disbursedBy        User?                  @relation("LoanDisbursedBy", fields: [disbursedById], references: [id])
  cancelledBy        User?                  @relation("LoanCancelledBy", fields: [cancelledById], references: [id])
  saleInvoice        Invoice?               @relation("FinancedSaleLoan", fields: [saleInvoiceId], references: [id])
  installments       LoanInstallment[]
  payments           LoanPayment[]
  ledgerEntries      LoanLedger[]
  documents          LoanDocument[]

  @@index([number])
  @@index([clientId])
  @@index([branchId])
  @@index([status])
  @@index([productType])
  @@index([startDate])
  @@index([nextPaymentDate])
  @@index([saleInvoiceId])
}

model LoanInstallment {
  id              String                  @id @default(uuid())
  loanId          String
  installmentNo   Int
  dueDate         DateTime
  openingBalance  Decimal                 @db.Decimal(12, 2)
  principalAmount Decimal                 @db.Decimal(12, 2)
  interestAmount  Decimal                 @db.Decimal(12, 2)
  totalAmount     Decimal                 @db.Decimal(12, 2)
  feeAmount       Decimal                 @default(0) @db.Decimal(12, 2)
  pendingAmount   Decimal                 @default(0) @db.Decimal(12, 2)
  paidPrincipal   Decimal                 @default(0) @db.Decimal(12, 2)
  paidInterest    Decimal                 @default(0) @db.Decimal(12, 2)
  paidLateFees    Decimal                 @default(0) @db.Decimal(12, 2)
  paidFees        Decimal                 @default(0) @db.Decimal(12, 2)
  paidAmount      Decimal                 @default(0) @db.Decimal(12, 2)
  lateFeeAmount   Decimal                 @default(0) @db.Decimal(12, 2)
  status          LoanInstallmentStatus   @default(PENDING)
  paidAt          DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  loan            Loan                    @relation(fields: [loanId], references: [id], onDelete: Cascade)
  payments        LoanPayment[]
  allocations     LoanPaymentAllocation[]

  @@unique([loanId, installmentNo])
  @@index([loanId])
  @@index([dueDate])
  @@index([status])
}

model LoanPayment {
  id              String                  @id @default(uuid())
  loanId          String
  clientId        String
  branchId        String?
  cashRegisterId  String?
  installmentId   String
  amount          Decimal                 @db.Decimal(12, 2)
  principalAmount Decimal                 @db.Decimal(12, 2)
  interestAmount  Decimal                 @db.Decimal(12, 2)
  lateFeeAmount   Decimal                 @default(0) @db.Decimal(12, 2)
  feeAmount       Decimal                 @default(0) @db.Decimal(12, 2)
  previousBalance Decimal                 @default(0) @db.Decimal(12, 2)
  newBalance      Decimal                 @default(0) @db.Decimal(12, 2)
  receiptNumber   String?                 @unique
  paymentDate     DateTime                @default(now())
  method          PaymentMethod
  reference       String?
  observations    String?
  status          LoanPaymentStatus       @default(POSTED)
  reversedAt      DateTime?
  reversedById    String?
  reversalReason  String?
  userId          String
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  installment     LoanInstallment         @relation(fields: [installmentId], references: [id], onDelete: Cascade)
  loan            Loan                    @relation(fields: [loanId], references: [id], onDelete: Cascade)
  client          Client                  @relation(fields: [clientId], references: [id])
  branch          Branch?                 @relation(fields: [branchId], references: [id])
  cashRegister    CashRegister?           @relation(fields: [cashRegisterId], references: [id])
  user            User                    @relation(fields: [userId], references: [id])
  reversedBy      User?                   @relation("LoanPaymentReversedBy", fields: [reversedById], references: [id])
  allocations     LoanPaymentAllocation[]
  documents       LoanDocument[]

  @@index([loanId])
  @@index([clientId])
  @@index([branchId])
  @@index([cashRegisterId])
  @@index([installmentId])
  @@index([paymentDate])
  @@index([status])
}

model LoanPaymentAllocation {
  id                String                @id @default(uuid())
  loanPaymentId     String
  loanInstallmentId String
  concept           LoanAllocationConcept
  amount            Decimal               @db.Decimal(12, 2)
  createdAt         DateTime              @default(now())
  loanPayment       LoanPayment           @relation(fields: [loanPaymentId], references: [id], onDelete: Cascade)
  loanInstallment   LoanInstallment       @relation(fields: [loanInstallmentId], references: [id], onDelete: Cascade)

  @@index([loanPaymentId])
  @@index([loanInstallmentId])
  @@index([concept])
}

model LoanLedger {
  id        String        @id @default(uuid())
  loanId    String
  eventType LoanEventType
  eventDate DateTime      @default(now())
  amount    Decimal?      @db.Decimal(12, 2)
  notes     String?
  metadata  Json?
  userId    String?
  createdAt DateTime      @default(now())
  loan      Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  user      User?         @relation(fields: [userId], references: [id])

  @@index([loanId])
  @@index([eventType])
  @@index([eventDate])
}

model LoanDocument {
  id             String           @id @default(uuid())
  loanId         String
  loanPaymentId  String?
  type           LoanDocumentType
  fileName       String
  fileUrl        String
  sentEmailAt    DateTime?
  sentWhatsAppAt DateTime?
  createdAt      DateTime         @default(now())
  loan           Loan             @relation(fields: [loanId], references: [id], onDelete: Cascade)
  loanPayment    LoanPayment?     @relation(fields: [loanPaymentId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([loanPaymentId])
  @@index([type])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  changes   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

